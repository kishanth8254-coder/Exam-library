{
  "entities": {
    "Book": {
      "title": "Book",
      "description": "Sri Lankan Tamil student textbook",
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "grade": {
          "type": "string"
        },
        "subject": {
          "type": "string"
        },
        "pdfUrl": {
          "type": "string"
        },
        "createdAt": {
          "type": "object",
          "description": "Firestore Server Timestamp"
        }
      },
      "required": [
        "id",
        "title",
        "grade",
        "subject",
        "pdfUrl",
        "createdAt"
      ]
    },
    "PastPaper": {
      "title": "PastPaper",
      "description": "Tamil student past examination papers (O/L and A/L)",
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "year": {
          "type": "string"
        },
        "examType": {
          "type": "string"
        },
        "subject": {
          "type": "string"
        },
        "pdfUrl": {
          "type": "string"
        },
        "createdAt": {
          "type": "object",
          "description": "Firestore Server Timestamp"
        }
      },
      "required": [
        "id",
        "year",
        "examType",
        "subject",
        "pdfUrl",
        "createdAt"
      ]
    },
    "User": {
      "title": "User",
      "description": "User profile indicating admin privilege",
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "email": {
          "type": "string"
        },
        "role": {
          "type": "string",
          "enum": [
            "admin",
            "student"
          ]
        }
      },
      "required": [
        "id",
        "name",
        "email",
        "role"
      ]
    }
  },
  "firestore": {
    "/books/{bookId}": {
      "schema": "Book",
      "description": "Collection of syllabus textbooks of Tamil medium"
    },
    "/pastPapers/{paperId}": {
      "schema": "PastPaper",
      "description": "Collection of G.C.E. O/L and G.C.E. A/L past papers in Tamil medium"
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "Collection of signed-up users and admins"
    }
  }
}
