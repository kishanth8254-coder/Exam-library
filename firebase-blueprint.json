{
  "entities": {
    "Book": {
      "title": "Book",
      "description": "Sri Lankan Tamil student textbook",
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "grade": {
          "type": "string"
        },
        "subject": {
          "type": "string"
        },
        "pdfUrl": {
          "type": "string"
        },
        "createdAt": {
          "type": "object",
          "description": "Firestore Server Timestamp"
        }
      },
      "required": [
        "id",
        "title",
        "grade",
        "subject",
        "pdfUrl",
        "createdAt"
      ]
    },
    "PastPaper": {
      "title": "PastPaper",
      "description": "Tamil student past examination papers (O/L and A/L)",
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "year": {
          "type": "string"
        },
        "examType": {
          "type": "string"
        },
        "subject": {
          "type": "string"
        },
        "pdfUrl": {
          "type": "string"
        },
        "createdAt": {
          "type": "object",
          "description": "Firestore Server Timestamp"
        }
      },
      "required": [
        "id",
        "year",
        "examType",
        "subject",
        "pdfUrl",
        "createdAt"
      ]
    },
    "User": {
      "title": "User",
      "description": "User profile indicating admin privilege and personal details",
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "email": {
          "type": "string"
        },
        "role": {
          "type": "string",
          "enum": [
            "admin",
            "student"
          ]
        },
        "accountType": {
          "type": "string",
          "enum": [
            "Student",
            "Teacher",
            "Parent",
            "Other"
          ]
        },
        "firstName": {
          "type": "string"
        },
        "lastName": {
          "type": "string"
        },
        "dob": {
          "type": "string"
        },
        "school": {
          "type": "string"
        },
        "phone": {
          "type": "string"
        }
      },
      "required": [
        "id",
        "name",
        "email",
        "role"
      ]
    },
    "SupportMessage": {
      "title": "SupportMessage",
      "description": "A user-submitted support message and admin reply",
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "userId": {
          "type": "string"
        },
        "fullName": {
          "type": "string"
        },
        "email": {
          "type": "string"
        },
        "message": {
          "type": "string"
        },
        "status": {
          "type": "string",
          "enum": [
            "pending",
            "replied"
          ]
        },
        "reply": {
          "type": "string"
        },
        "createdAt": {
          "type": "object",
          "description": "Firestore Server Timestamp"
        },
        "repliedAt": {
          "type": "object",
          "description": "Firestore Server Timestamp"
        }
      },
      "required": [
        "id",
        "fullName",
        "email",
        "message",
        "status",
        "createdAt"
      ]
    },
    "Traffic": {
      "title": "Traffic",
      "description": "Daily traffic logging counts",
      "type": "object",
      "properties": {
        "date": {
          "type": "string"
        },
        "count": {
          "type": "integer"
        }
      },
      "required": [
        "date",
        "count"
      ]
    }
  },
  "firestore": {
    "/books/{bookId}": {
      "schema": "Book",
      "description": "Collection of syllabus textbooks of Tamil medium"
    },
    "/pastPapers/{paperId}": {
      "schema": "PastPaper",
      "description": "Collection of G.C.E. O/L and G.C.E. A/L past papers in Tamil medium"
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "Collection of signed-up users and admins"
    },
    "/supportMessages/{messageId}": {
      "schema": "SupportMessage",
      "description": "Collection of customer support requests and replies"
    },
    "/traffic/{trafficId}": {
      "schema": "Traffic",
      "description": "Daily visit hits tracker"
    }
  }
}
